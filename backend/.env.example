# Environment Configuration
# Copy to .env and fill in actual values

# Application
APP_NAME=TaskFlow AI Customer Success Agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/taskflow_crm
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INQUIRIES=customer-inquiries
KAFKA_TOPIC_RESPONSES=customer-responses
KAFKA_CONSUMER_GROUP=agent-processors

# OpenAI (or Groq API - they use same interface)
OPENAI_API_KEY=sk-your-key-here  # Use gsk-... for Groq, sk-... for OpenAI
OPENAI_MODEL=llama-3.1-70b-versatile  # Current Groq models: llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Groq-specific settings (set USE_GROQ=true to use Groq instead of OpenAI)
USE_GROQ=true
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Feature Flags (set to false to disable AI processing for testing)
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_AUTO_ESCALATION=true

# Gmail API
GMAIL_CREDENTIALS_FILE=credentials/gmail-credentials.json
GMAIL_TOKEN_FILE=credentials/gmail-token.json
GMAIL_SUPPORT_EMAIL=support@taskflow.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_WEBHOOK_URL=https://your-domain.com/api/webhooks/whatsapp

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Performance
MAX_CONCURRENT_REQUESTS=1000
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=60

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_METRICS=true

# Feature Flags
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_AUTO_ESCALATION=true
ENABLE_DAILY_REPORTS=true
